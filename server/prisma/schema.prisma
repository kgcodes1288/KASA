generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  googleId  String?  @unique
  role      Role
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings              Listing[]       @relation("HostListings")
  jobs                  Job[]
  coHosting             ListingCoHost[] @relation("CoHostUser")
  maintenanceTasks      MaintenanceTask[]
  assignedByTasks       MaintenanceTask[] @relation("TaskAssignedBy")
  contractors           Contractor[]
  notifications         Notification[]
}

enum Role {
  host
  cleaner
}

model Listing {
  id          String    @id @default(cuid())
  name        String
  address     String?
  icalUrl     String
  lastSynced  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hostId      String

  host              User              @relation("HostListings", fields: [hostId], references: [id], onDelete: Cascade)
  rooms             Room[]
  jobs              Job[]
  coHosts           ListingCoHost[]   @relation("CoHostListing")
  maintenanceTasks  MaintenanceTask[]
  jobTokens         JobToken[]
}

model ListingCoHost {
  id          String        @id @default(cuid())
  listingId   String
  userId      String?
  role        CoHostRole
  status      CoHostStatus  @default(PENDING)
  inviteToken String        @unique
  inviteEmail String?
  createdAt   DateTime      @default(now())

  listing     Listing       @relation("CoHostListing", fields: [listingId], references: [id], onDelete: Cascade)
  user        User?         @relation("CoHostUser", fields: [userId], references: [id], onDelete: Cascade)
}

enum CoHostRole {
  COHOST
  VIEW_ONLY
}

enum CoHostStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum EntityType {
  ROOM
  APPLIANCE
  SPACE
}

model Room {
  id         String     @id @default(cuid())
  name       String
  entityType EntityType @default(ROOM)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  listingId  String

  listing          Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  checklistItems   ChecklistTemplate[]
  jobs             Job[]
  maintenanceTasks MaintenanceTask[]
}

model MaintenanceTask {
  id               String     @id @default(cuid())
  title            String
  notes            String?
  intervalMonths   Int
  isRecurring      Boolean    @default(true)
  taskType         TaskType   @default(MAINTENANCE)
  paymentAmount    String?
  attachments      String[]   @default([])
  lastServicedAt   DateTime?
  nextDueAt        DateTime
  status           TaskStatus @default(PENDING)
  notificationSent Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  listingId        String
  roomId           String?
  assignedUserId   String?
  assignedByUserId String?

  listing            Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  room               Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  assignedUser       User?                @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedBy         User?                @relation("TaskAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  maintenanceTokens  MaintenanceToken[]
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum TaskType {
  MAINTENANCE
  ACTION
  PAYMENT_REQUEST
}

// ── New: contractor token for maintenance tasks ──────────────────────────────
model MaintenanceToken {
  id          String    @id @default(cuid())
  token       String    @unique
  phone       String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  taskId      String

  task        MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ChecklistTemplate {
  id     String @id @default(cuid())
  text   String
  order  Int    @default(0)
  roomId String

  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Job {
  id             String    @id @default(cuid())
  guestName      String    @default("Airbnb Guest")
  checkoutDate   DateTime
  checkinDate    DateTime?
  status         JobStatus @default(pending)
  smsSent        Boolean   @default(false)
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  listingId      String
  roomId         String
  cleanerId      String?

  listing        Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  room           Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  cleaner        User?          @relation(fields: [cleanerId], references: [id], onDelete: SetNull)
  checklistItems JobChecklist[]
}

enum JobStatus {
  pending
  in_progress
  completed
}

model JobChecklist {
  id          String    @id @default(cuid())
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  jobId       String

  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobToken {
  id             String         @id @default(cuid())
  token          String         @unique
  phone          String
  contractorName String?
  status         JobTokenStatus @default(PENDING)
  checkoutDate   DateTime
  expiresAt      DateTime
  createdAt      DateTime       @default(now())
  listingId      String

  listing        Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

enum JobTokenStatus {
  PENDING
  ACCEPTED
  WITHDRAWN
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      NotifType
  title     String
  message   String
  read      Boolean   @default(false)
  listingId String?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotifType {
  COHOST_ACCEPTED
  JOB_CREATED
  CONTRACTOR_ACCEPTED
  CONTRACTOR_REJECTED
  CONTRACTOR_STARTED
  JOB_COMPLETED
  TASK_ASSIGNED
}

model Contractor {
  id        String   @id @default(cuid())
  name      String
  phone     String
  trade     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hostId    String
  smsConsent Boolean @default(false)

  host      User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
}